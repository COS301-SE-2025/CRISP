[run]
source = apps
omit = 
    */migrations/*
    */venv/*
    */env/*
    manage.py
    manage_unified.py
    managetrust.py
    */settings/*
    */wsgi.py
    */asgi.py
    */__pycache__/*
    */test_*integration*
    */test_*api*
    */test_*admin*
    */test_*formatting*
    */test_*comprehensive*
    */test_*server*
    */test_*final*
    */test_*simple*
    */test_*system*
    */clear_*
    */debug_*
    */prepare_*
    */remove_*
    */reset_*
    */run_*
    */simple_*
    */verify_*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    class .*\(Protocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov